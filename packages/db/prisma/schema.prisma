datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Lens {
  id           String         @id @default(uuid())
  name         String
  brand        String
  type         String         // daily, weekly, monthly, biweekly
  power        Float
  baseCurve    Float
  diameter     Float
  description  String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  prices       PriceHistory[]
}

model Retailer {
  id           String         @id @default(uuid())
  name         String
  url          String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  prices       PriceHistory[]
}

model PriceHistory {
  id         String   @id @default(uuid())
  price      Float
  timestamp  DateTime @default(now())
  
  lensId     String
  lens       Lens     @relation(fields: [lensId], references: [id], onDelete: Cascade)
  
  retailerId String
  retailer   Retailer @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@index([lensId])
  @@index([retailerId])
}
