# =============================================================================
# Cerebrum.md Git Ignore Configuration
# =============================================================================
# This file prevents local outputs of initialize.sh and other system-specific
# files from being committed to the harness repository.
# Reference: User Request (ad1090b7-ff6d-45a2-bb3f-ad8a73c38c4a)
# =============================================================================

# --- Cerebrum Provider Initialization Outputs ---------------------------------
# Prevents committing provider configurations generated locally via scripts/initialize.sh
.agents/
.claude/
.cursor/
CLAUDE.md
.cerebrum-init.md

# --- OS-Specific Files --------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon\r
._*
.Spotlight-V100
.Trashes
Brushish

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

